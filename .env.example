# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_starter?schema=public"

# ── Auth.js ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Optional OAuth (Google). Leave blank to disable.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Billing (Stripe) — skeleton; safe to leave blank in dev ──────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Set to your Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX) to enable
# GA4. Leave blank to disable — don't ship someone else's ID when you clone this.
NEXT_PUBLIC_GA_ID=""
